  {name:'ether2',type:'ether',disabled:false,running:false,comment:'',mac:'04:F4:1C:20:7A:AB','link-downs':'0','last-link-up-time':'','tx-byte':0,'rx-byte':0},
  {name:'ether3',type:'ether',disabled:false,running:false,comment:'',mac:'04:F4:1C:20:7A:AC','link-downs':'0','last-link-up-time':'','tx-byte':0,'rx-byte':0},
  {name:'ether4',type:'ether',disabled:false,running:false,comment:'',mac:'04:F4:1C:20:7A:AD','link-downs':'0','last-link-up-time':'','tx-byte':0,'rx-byte':0},
