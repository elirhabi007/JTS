let demoCur = {};
DEMO_BASE.forEach(i => { demoCur[i.name] = {tx: i['tx-byte'], rx: i['rx-byte']}; });

// DEMO TRAFFIC SPEEDS (Mbps avg)
const DEMO_SPEED = {
  'sfp-sfpplus1':    {tx:85,  rx:320},
  'VLAN-631':        {tx:80,  rx:300},
  'ether1-LINK-TO-DISTRIBUSI': {tx:300, rx:80},
  'zerotier1':       {tx:0.5, rx:0.08},
  'lo':              {tx:0.01,rx:0.01},
};

// ===== INIT =====
window.onload = () => {
  initCharts();
  setInterval(() => { document.getElementById('hdrTime').textContent = new Date().toLocaleTimeString('en-GB'); }, 1000);
  log('Sistem ready. Klik CONFIG → isi kredensial → START.', 'info');
};

// ===== CHARTS =====
const C = {
  base: {responsive:true,maintainAspectRatio:false,animation:{duration:200},
    plugins:{legend:{labels:{color:'#4a7a9b',font:{family:'Share Tech Mono',size:9},boxWidth:10}}},
    scales:{
      x:{ticks:{color:'#4a7a9b',font:{family:'Share Tech Mono',size:8},maxTicksLimit:6,maxRotation:0},grid:{color:'rgba(26,58,82,.3)'}},
      y:{ticks:{color:'#4a7a9b',font:{family:'Share Tech Mono',size:9}},grid:{color:'rgba(26,58,82,.3)'},beginAtZero:true}
    }
  }
};

function lds(label, hex, fill=0.07) {
  return {label, data:Array(MAX).fill(0), borderColor:hex,
    backgroundColor:hex+(Math.round(fill*255).toString(16).padStart(2,'0')),
    borderWidth:2, pointRadius:0, fill:true, tension:0.35};
}

function initCharts() {
  const mk = (id, ds, extra={}) => {
    const el = document.getElementById(id); if (!el) return null;
    const opts = JSON.parse(JSON.stringify(C.base));
    if (extra.yMax !== undefined) opts.scales.y.max = extra.yMax;
    return new Chart(el, {type: extra.type || 'line', data:{labels:Array(MAX).fill(''), datasets:ds}, options:opts});
  };
  charts.sfp  = mk('cSfp',  [lds('TX Mbps','#ff6b35'), lds('RX Mbps','#00d4ff')]);
  charts.eth  = mk('cEth',  [lds('TX Mbps','#ffd700'), lds('RX Mbps','#00ff88')]);
  charts.vlan = mk('cVlan', [lds('TX Mbps','#ff3366'), lds('RX Mbps','#a855f7')]);
  charts.all  = mk('cAll',  [
    lds('SFP TX','#ff6b35'), lds('SFP RX','#00d4ff'),
    lds('ETH1 TX','#ffd700'), lds('ETH1 RX','#00ff88'),
  ]);
  charts.sys  = mk('cSys',  [lds('CPU %','#ffd700'), lds('MEM used %','#00ff88')], {yMax:100});
}

function push(chart, ...vals) {
  if (!chart) return;
  chart.data.labels.push('');
  if (chart.data.labels.length > MAX) chart.data.labels.shift();
  vals.forEach((v,i) => {
    chart.data.datasets[i].data.push(typeof v === 'number' ? +v.toFixed(3) : 0);
    if (chart.data.datasets[i].data.length > MAX) chart.data.datasets[i].data.shift();
  });
  chart.update('none');
}

// ===== MONITOR CONTROL =====
function startMonitor() {
  if (running) return;
  mode = document.getElementById('modeSelect').value;
  running = true; pollNum = 0; prevBytes = {};
  document.getElementById('startBtn').style.display = 'none';
  document.getElementById('stopBtn').style.display = 'inline-block';
  document.getElementById('pollCount').style.display = 'inline';
  document.getElementById('cfg').classList.add('hidden');
  document.getElementById('cfgBtn').textContent = '⚙ CONFIG';
  setDot('poll','CONNECTING...');

  const msg = mode === 'demo'
    ? 'Demo mode — simulasi data router nyata (RB5009, sfp-sfpplus1 UPLINK-JTS).'
    : `Live mode → ${document.getElementById('apiUrl').value}/rest/interface`;
  log(msg, 'info');
  if (mode === 'demo') toast('Demo aktif', 'ok');

  poll();
  const iv = parseInt(document.getElementById('ivSel').value);
  timer = setInterval(poll, iv);
}

function stopMonitor() {
  running = false;
  if (timer) { clearInterval(timer); timer = null; }
  setDot('','OFFLINE');
  document.getElementById('startBtn').style.display = 'inline-block';
  document.getElementById('stopBtn').style.display = 'none';
  document.getElementById('pollCount').style.display = 'none';
  log('Monitor dihentikan.', 'warn');
  toast('Dihentikan','fail');
}

function onIntervalChange() {
  if (!running) return;
  clearInterval(timer);
  const iv = parseInt(document.getElementById('ivSel').value);
  timer = setInterval(poll, iv);
  log('Interval → ' + iv/1000 + 's', 'info');
}

// ===== POLL =====
async function poll() {
  if (!running) return;
  pollNum++;
  document.getElementById('pNum').textContent = pollNum;

  if (mode === 'demo') { doPollDemo(); return; }

  const base = document.getElementById('apiUrl').value.trim().replace(/\/$/,'');
  const auth = 'Basic ' + btoa(document.getElementById('apiUser').value + ':' + document.getElementById('apiPass').value);

  try {
    setDot('poll','POLLING...');
    const [r1, r2] = await Promise.all([
      fetch(base + '/rest/interface', {headers:{Authorization:auth}}),
      fetch(base + '/rest/system/resource', {headers:{Authorization:auth}}).catch(()=>null)
    ]);
    if (!r1.ok) {
      const t = await r1.text().catch(()=>r1.status);
      throw new Error(`HTTP ${r1.status} — ${String(t).slice(0,100)}`);
    }
    const ifaces = await r1.json();
    const sys = r2 && r2.ok ? await r2.json() : null;
    processIfaces(ifaces);
    if (sys) processSys(sys);
    setDot('ok','LIVE');
    if (pollNum === 1) { log(`✓ Connected. ${ifaces.length} interfaces.`, 'info'); toast('Connected ✓','ok'); }
  } catch(e) {
    setDot('err','ERROR');
    log('Poll error: ' + e.message, 'err');
    if (pollNum <= 3) toast(e.message.slice(0,70), 'fail');
  }
}

function doPollDemo() {
  demoTick++;
  const interval = parseInt(document.getElementById('ivSel').value) / 1000;
  const ifaces = DEMO_BASE.map(base => {
    const n = base.name;
    const sp = DEMO_SPEED[n];
    let txDelta = 0, rxDelta = 0;
    if (sp && base.running) {
      const jitter = () => 0.6 + Math.random()*0.8 + Math.sin(demoTick*0.25 + n.length*0.3)*0.3;
      txDelta = Math.round(sp.tx * 1e6 / 8 * jitter() * interval);
      rxDelta = Math.round(sp.rx * 1e6 / 8 * jitter() * interval);
    }
    demoCur[n].tx += txDelta;
    demoCur[n].rx += rxDelta;
    return {...base, 'tx-byte': demoCur[n].tx, 'rx-byte': demoCur[n].rx};
  });
  processIfaces(ifaces);
  processSys({
    'cpu-load': String(Math.round(12 + 18*Math.abs(Math.sin(demoTick*.12)) + Math.random()*8)),
    'total-memory':'536870912','free-memory':String(Math.round(210e6 + 40e6*Math.sin(demoTick*.06))),
    uptime:'4d2h13m', version:'7.14.3 (stable)', 'board-name':'RB5009UG+S+','free-hdd-space':'52428800'
  });
  setDot('ok','DEMO');
}

// ===== PROCESS INTERFACES =====
function processIfaces(rawIfaces) {
  const now = Date.now();
  const rates = {};

  rawIfaces.forEach(iface => {
    const n = iface.name;
    const txB = parseInt(iface['tx-byte'] || 0);
    const rxB = parseInt(iface['rx-byte'] || 0);
    if (prevBytes[n] && now > prevBytes[n].ts) {
      const dt = (now - prevBytes[n].ts) / 1000;
      rates[n] = {
        tx: Math.max(0, (txB - prevBytes[n].tx) * 8 / dt / 1e6),
        rx: Math.max(0, (rxB - prevBytes[n].rx) * 8 / dt / 1e6)
      };
    } else { rates[n] = {tx:0, rx:0}; }
    prevBytes[n] = {tx:txB, rx:rxB, ts:now};
  });

  renderKPI(rawIfaces, rates);
  renderBwBars(rawIfaces, rates);
  renderIfTable(rawIfaces, rates);
  if (pollNum > 1) updateCharts(rawIfaces, rates);
}

// ===== RENDER KPI =====
function renderKPI(ifaces, rates) {
  const sfp = ifaces.find(i => i.name === 'sfp-sfpplus1');
  if (sfp) {
    const r = rates['sfp-sfpplus1'] || {tx:0,rx:0};
    set('k-tx', pollNum<=1 ? '...' : r.tx.toFixed(2));
    set('k-rx', pollNum<=1 ? '...' : r.rx.toFixed(2));
    const [tv,tu] = fmtB(parseInt(sfp['tx-byte']||0));
    const [rv,ru] = fmtB(parseInt(sfp['rx-byte']||0));
    set('k-txT', tv); set('k-txU', tu);
    set('k-rxT', rv); set('k-rxU', ru);
  }
  const up = ifaces.filter(i => i.running===true||i.running==='true').length;
  set('k-up', up); set('k-total', ifaces.length);
  const ld = ifaces.reduce((s,i)=>s+parseInt(i['link-downs']||0),0);
  set('k-ld', ld);
}

// ===== RENDER BW BARS =====
function renderBwBars(ifaces, rates) {
  const active = ifaces.filter(i => (i.running===true||i.running==='true') && i.type!=='loopback');
  if (!active.length) { document.getElementById('bwBars').innerHTML='<div class="empty">TIDAK ADA INTERFACE AKTIF</div>'; return; }
  const maxR = Math.max(...active.flatMap(i=>[rates[i.name]?.tx||0, rates[i.name]?.rx||0]), 0.1);
  const total = active.reduce((s,i)=>s+(rates[i.name]?.tx||0)+(rates[i.name]?.rx||0),0);
  set('bwMeta', fmtRate(total) + ' combined');
  document.getElementById('bwBars').innerHTML = active.map(iface => {
    const r = rates[iface.name]||{tx:0,rx:0};
    const txP = Math.min(100,(r.tx/maxR)*100);
    const rxP = Math.min(100,(r.rx/maxR)*100);
    const cmt = iface.comment ? ` <span style="color:var(--muted);font-size:9px;margin-left:6px">${iface.comment}</span>` : '';
    return `<div class="bw-item">
      <div class="bw-head"><span class="bw-name">${iface.name}${cmt}</span><span class="bw-type">${iface.type}</span></div>
      <div class="bw-row bw-tx"><span class="bw-dir">TX</span><div class="bw-track"><div class="bw-fill" style="width:${txP}%"></div></div><span class="bw-val">${fmtRate(r.tx)}</span></div>
      <div class="bw-row bw-rx"><span class="bw-dir">RX</span><div class="bw-track"><div class="bw-fill" style="width:${rxP}%"></div></div><span class="bw-val">${fmtRate(r.rx)}</span></div>
    </div>`;
  }).join('');
}

// ===== RENDER TABLE =====
function renderIfTable(ifaces, rates) {
  set('ifMeta', ifaces.length + ' interfaces, ' + ifaces.filter(i=>i.running===true||i.running==='true').length + ' running');
  document.getElementById('ifBody').innerHTML = ifaces.map((iface, idx) => {
    const up = iface.running===true||iface.running==='true';
    const dis = iface.disabled===true||iface.disabled==='true';
    const r = rates[iface.name]||{tx:0,rx:0};
    const txB = parseInt(iface['tx-byte']||0);
    const rxB = parseInt(iface['rx-byte']||0);
    const ld = parseInt(iface['link-downs']||0);
    const badge = dis?'b-dis':up?'b-up':'b-dn';
    const stxt = dis?'DISABLED':up?'UP':'DOWN';
    const lup = iface['last-link-up-time'] || '—';
    return `<tr>
      <td class="tm">${idx+1}</td>
      <td class="hl">${iface.name}</td>
      <td class="tm">${iface.type}</td>
      <td><span class="badge ${badge}">${stxt}</span></td>
      <td class="${up?'to':'tm'}">${fmtRate(r.tx)}</td>
      <td class="${up?'tg':'tm'}">${fmtRate(r.rx)}</td>
      <td class="tm">${fmtBStr(txB)}</td>
      <td class="tm">${fmtBStr(rxB)}</td>
      <td class="${ld>0?'ty':'tm'}">${ld}</td>
      <td class="tm" style="font-size:10px">${lup}</td>
      <td class="tm" style="font-size:10px">${iface['mac-address']||'—'}</td>
      <td class="tm">${iface.comment||'—'}</td>
    </tr>`;
  }).join('');
}

// ===== CHARTS UPDATE =====
function updateCharts(ifaces, rates) {
  const sfp  = rates['sfp-sfpplus1']||{tx:0,rx:0};
  const eth  = rates['ether1-LINK-TO-DISTRIBUSI']||{tx:0,rx:0};
  const vlan = rates['VLAN-631']||{tx:0,rx:0};
  push(charts.sfp, sfp.tx, sfp.rx);
  push(charts.eth, eth.tx, eth.rx);
  push(charts.vlan, vlan.tx, vlan.rx);
  push(charts.all, sfp.tx, sfp.rx, eth.tx, eth.rx);
}

// ===== SYSTEM =====
function processSys(sys) {
  const cpu = parseInt(sys['cpu-load']||0);
  const memT = parseInt(sys['total-memory']||1);
  const memF = parseInt(sys['free-memory']||0);
  const memPct = Math.round(((memT-memF)/memT)*100);
  set('s-cpu', cpu);
  set('s-mem', Math.round(memF/1024/1024));
  set('s-up', sys.uptime||'—');
  set('s-ros', sys.version||'—');
  set('s-board', sys['board-name']||'—');
  set('s-hdd', Math.round(parseInt(sys['free-hdd-space']||0)/1024/1024));
  push(charts.sys, cpu, memPct);
}

// ===== UTILS =====
function fmtRate(mbps) {
  if (!mbps || mbps < 0) return '0';
  if (mbps < 0.001) return (mbps*1e6).toFixed(0)+' bps';
  if (mbps < 1) return (mbps*1000).toFixed(1)+' Kbps';
  if (mbps >= 1000) return (mbps/1000).toFixed(2)+' Gbps';
  return mbps.toFixed(2)+' Mbps';
}
function fmtB(b) {
  if (b>=1e15) return [(b/1e15).toFixed(2),'PB'];
  if (b>=1e12) return [(b/1e12).toFixed(2),'TB'];
  if (b>=1e9)  return [(b/1e9).toFixed(2),'GB'];
  if (b>=1e6)  return [(b/1e6).toFixed(1),'MB'];
  if (b>=1e3)  return [(b/1e3).toFixed(0),'KB'];
  return [b,'B'];
}
function fmtBStr(b) { const [v,u]=fmtB(b); return v+' '+u; }
function set(id, v) { const el=document.getElementById(id); if(el) el.textContent=v; }

// ===== UI =====
function setDot(cls, txt) {
  document.getElementById('dot').className = 'dot '+(cls||'');
  document.getElementById('hdrStatus').textContent = txt;
}
function toggleCfg() {
  const cfg = document.getElementById('cfg');
  cfg.classList.toggle('hidden');
  document.getElementById('cfgBtn').textContent = cfg.classList.contains('hidden') ? '⚙ CONFIG' : '✕ TUTUP';
}
function onModeChange() {
  const demo = document.getElementById('modeSelect').value === 'demo';
  document.getElementById('cfgNote').innerHTML = demo
    ? '<b>Demo Mode:</b> Simulasi realtime berbasis snapshot router nyata (RB5009UG+S+). Interface: sfp-sfpplus1 UPLINK-JTS, ether1-LINK-TO-DISTRIBUSI, VLAN-631, zerotier1, dll. Tidak memerlukan koneksi ke router.'
    : `<b>Live Mode:</b> Fetch langsung ke REST API. Endpoint: <b>${document.getElementById('apiUrl').value}/rest/interface</b>. Jika ada error CORS, pastikan mengakses dari jaringan yang sama atau setup CORS di RouterOS.`;
}
function switchTab(name, el) {
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  ['overview','interfaces','traffic','system'].forEach(t => {
    document.getElementById('tab-'+t).style.display = t===name?'':'none';
  });
}
function log(msg, type='info') {
  const body = document.getElementById('logBody');
  const now = new Date().toLocaleTimeString('en-GB');
  const tags = {info:'INFO',warn:'WARN',err:'ERROR'};
  const div = document.createElement('div');
  div.className = 'll '+(type||'info');
  div.innerHTML = `<span class="tag">[${tags[type]||type}]</span> ${now} — ${msg}`;
  body.appendChild(div);
  body.scrollTop = body.scrollHeight;
  if (body.children.length > 150) body.removeChild(body.firstChild);
}
function clearLog() { document.getElementById('logBody').innerHTML = ''; }
function toast(msg, cls) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'show '+(cls||'');
  clearTimeout(t._t); t._t = setTimeout(()=>t.className='', 3500);
}
</script>
